    <script>
        // ========== 全局变量 ==========
        const themeBtn = document.getElementById('themeBtn');
        const htmlDom = document.documentElement;
        const goFav = document.getElementById('goFav');
        const backHome = document.getElementById('backHome');
        const mainPage = document.querySelector('.main-page');
        const favPage = document.getElementById('favPage');
        const favGrid = document.getElementById('favGrid');
        const favEmpty = document.getElementById('favEmpty');
        const favBtns = document.querySelectorAll('.fav-btn');

        // 收藏数据 本地存储key
        const FAV_KEY = 'decor_favorite';

        // ========== 主题切换 + 本地存储 ==========
        const initTheme = localStorage.getItem('decorTheme') || 'light';
        if(initTheme === 'dark'){
            htmlDom.setAttribute('data-theme','dark');
            themeBtn.innerHTML = '<i class="fa fa-sun-o"></i> 亮色模式';
        }
        themeBtn.addEventListener('click', () => {
            if(htmlDom.hasAttribute('data-theme')){
                htmlDom.removeAttribute('data-theme');
                themeBtn.innerHTML = '<i class="fa fa-moon-o"></i> 切换主题';
                localStorage.setItem('decorTheme','light');
            } else {
                htmlDom.setAttribute('data-theme','dark');
                themeBtn.innerHTML = '<i class="fa fa-sun-o"></i> 亮色模式';
                localStorage.setItem('decorTheme','dark');
            }
        });

        // ========== 收藏功能核心方法 ==========
        // 获取收藏列表
        function getFavList(){
            let list = localStorage.getItem(FAV_KEY);
            return list ? JSON.parse(list) : [];
        }
        // 保存收藏列表
        function saveFavList(list){
            localStorage.setItem(FAV_KEY, JSON.stringify(list));
        }
        // 初始化收藏按钮状态
        function initFavStatus(){
            const favList = getFavList();
            favBtns.forEach(btn => {
                const item = btn.closest('.style-item');
                const id = item.dataset.id;
                if(favList.find(item => item.id === id)){
                    btn.classList.add('active');
                    btn.innerHTML = '<i class="fa fa-heart"></i>';
                }else{
                    btn.classList.remove('active');
                    btn.innerHTML = '<i class="fa fa-heart-o"></i>';
                }
            });
        }
        // 渲染收藏页面
        function renderFavPage(){
            const favList = getFavList();
            favGrid.innerHTML = '';
            if(favList.length === 0){
                favEmpty.style.display = 'block';
                return;
            }
            favEmpty.style.display = 'none';
            favList.forEach(item => {
                const div = document.createElement('div');
                div.className = 'style-item';
                div.dataset.id = item.id;
                div.innerHTML = `
                    <img src="${item.img}" alt="${item.name}" loading="lazy">
                    <div class="style-name">${item.name}</div>
                    <button class="fav-btn active"><i class="fa fa-heart"></i></button>
                `;
                favGrid.appendChild(div);
            });
            // 收藏页取消收藏事件
            favGrid.querySelectorAll('.fav-btn').forEach(btn => {
                btn.addEventListener('click', function(){
                    const item = this.closest('.style-item');
                    const id = item.dataset.id;
                    let list = getFavList();
                    list = list.filter(ele => ele.id !== id);
                    saveFavList(list);
                    renderFavPage();
                    initFavStatus();
                });
            });
        }

        // ========== 首页收藏点击事件 ==========
        favBtns.forEach(btn => {
            btn.addEventListener('click', function(e){
                e.stopPropagation();
                const item = this.closest('.style-item');
                const id = item.dataset.id;
                const name = item.dataset.name;
                const img = item.dataset.img;
                let favList = getFavList();

                // 已收藏 → 取消
                const index = favList.findIndex(ele => ele.id === id);
                if(index > -1){
                    favList.splice(index,1);
                    this.classList.remove('active');
                    this.innerHTML = '<i class="fa fa-heart-o"></i>';
                }else{
                    // 未收藏 → 添加
                    favList.push({id,name,img});
                    this.classList.add('active');
                    this.innerHTML = '<i class="fa fa-heart"></i>';
                }
                saveFavList(favList);
            });
        });

        // ========== 页面切换（首页 / 收藏页） ==========
        // 进入收藏页
        goFav.addEventListener('click', () => {
            mainPage.classList.add('hide');
            favPage.classList.add('active');
            renderFavPage();
            window.scrollTo(0,0);
        });
        // 返回首页
        backHome.addEventListener('click', () => {
            mainPage.classList.remove('hide');
            favPage.classList.remove('active');
            window.scrollTo(0,0);
        });

        // 页面加载初始化
        window.onload = function(){
            initFavStatus();
        }
    </script>
