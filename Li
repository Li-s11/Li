<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="专业全屋整装、新房翻新、工装设计、全屋定制一站式装修服务">
    <title>臻品装饰 | 一站式高端装修设计</title>
    <!-- 图标库 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/font-awesome@4.7.0/css/font-awesome.min.css">
    <style>
        /* ===================== 全局重置 & 基础配置 ===================== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
            font-size: 16px;
        }

        body {
            font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
            line-height: 1.8;
            overflow-x: hidden;
            transition: background-color 0.4s ease, color 0.4s ease;
        }

        /* CSS变量 - 主题系统 */
        :root {
            --color-primary: #2563eb;
            --color-primary-light: #3b82f6;
            --color-primary-gradient: linear-gradient(135deg, #2563eb, #60a5fa);
            --color-text-main: #1f2937;
            --color-text-sub: #6b7280;
            --color-bg-main: #ffffff;
            --color-bg-card: #f9fafb;
            --color-bg-section: #f3f4f6;
            --color-border: #e5e7eb;
            --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.08);
            --shadow-md: 0 4px 16px rgba(0, 0, 0, 0.12);
            --shadow-lg: 0 8px 24px rgba(0, 0, 0, 0.16);
            --radius-sm: 6px;
            --radius-md: 12px;
            --radius-lg: 20px;
            --color-fav: #ef4444;
        }

        [data-theme="dark"] {
            --color-primary: #3b82f6;
            --color-primary-light: #60a5fa;
            --color-text-main: #f3f4f6;
            --color-text-sub: #9ca3af;
            --color-bg-main: #111827;
            --color-bg-card: #1f2937;
            --color-bg-section: #182234;
            --color-border: #374151;
            --shadow-sm: 0 2px 8px rgba(0, 0, 0, 0.2);
            --shadow-md: 0 4px 16px rgba(0, 0, 0.25);
            --shadow-lg: 0 8px 24px rgba(0, 0, 0, 0.3);
        }

        body {
            background-color: var(--color-bg-main);
            color: var(--color-text-main);
        }

        a {
            text-decoration: none;
            color: inherit;
        }

        ul {
            list-style: none;
        }

        img {
            max-width: 100%;
            display: block;
        }

        .container {
            max-width: 1440px;
            margin: 0 auto;
            padding: 0 24px;
        }

        .section {
            padding: 80px 0;
        }

        .section-bg {
            background-color: var(--color-bg-section);
        }

        .section-title {
            text-align: center;
            margin-bottom: 60px;
        }

        .section-title h2 {
            font-size: 36px;
            font-weight: 700;
            margin-bottom: 12px;
            position: relative;
            display: inline-block;
        }

        .section-title h2::after {
            content: "";
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
            bottom: -10px;
            width: 60px;
            height: 3px;
            background: var(--color-primary-gradient);
            border-radius: 2px;
        }

        .section-title p {
            color: var(--color-text-sub);
            font-size: 16px;
            margin-top: 16px;
        }

        .btn {
            display: inline-block;
            padding: 12px 32px;
            background: var(--color-primary-gradient);
            color: #fff;
            border-radius: var(--radius-sm);
            font-weight: 500;
            box-shadow: var(--shadow-md);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            border: none;
            cursor: pointer;
        }

        .btn:hover {
            transform: translateY(-3px);
            box-shadow: var(--shadow-lg);
        }

        /* ===================== 顶部导航栏 ===================== */
        .header {
            position: sticky;
            top: 0;
            z-index: 999;
            background-color: var(--color-bg-card);
            border-bottom: 1px solid var(--color-border);
            backdrop-filter: blur(8px);
        }

        .nav {
            display: flex;
            align-items: center;
            justify-content: space-between;
            height: 70px;
        }

        .logo {
            font-size: 24px;
            font-weight: 700;
            color: var(--color-primary);
        }

        .nav-menu {
            display: flex;
            gap: 36px;
        }

        .nav-menu a {
            font-size: 16px;
            font-weight: 500;
            position: relative;
            padding: 8px 0;
        }

        .nav-menu a::after {
            content: "";
            position: absolute;
            left: 0;
            bottom: 0;
            width: 0;
            height: 2px;
            background-color: var(--color-primary);
            transition: width 0.3s ease;
        }

        .nav-menu a:hover::after {
            width: 100%;
        }

        .theme-toggle {
            padding: 8px 16px;
            border-radius: var(--radius-sm);
            background-color: var(--color-bg-section);
            border: 1px solid var(--color-border);
            cursor: pointer;
            transition: all 0.3s ease;
            margin-left: 12px;
        }

        .theme-toggle:hover {
            background-color: var(--color-primary);
            color: #fff;
        }

        /* 移动端菜单隐藏 */
        @media (max-width: 992px) {
            .nav-menu {
                display: none;
            }
        }

        /* ===================== 全屏轮播横幅 ===================== */
        .banner {
            height: 85vh;
            min-height: 500px;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            color: #fff;
        }

        .banner-bg {
            position: absolute;
            inset: 0;
            z-index: -1;
        }

        .banner-bg img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .banner-mask {
            position: absolute;
            inset: 0;
            background-color: rgba(0, 0, 0, 0.55);
        }

        .banner-content {
            max-width: 800px;
            padding: 0 24px;
            z-index: 1;
        }

        .banner-content h1 {
            font-size: 52px;
            margin-bottom: 24px;
            line-height: 1.2;
        }

        .banner-content p {
            font-size: 20px;
            margin-bottom: 36px;
            opacity: 0.9;
        }

        /* ===================== 房屋类型板块 ===================== */
        .house-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(360px, 1fr));
            gap: 32px;
        }

        .house-card {
            background-color: var(--color-bg-card);
            border-radius: var(--radius-lg);
            overflow: hidden;
            box-shadow: var(--shadow-sm);
            transition: transform 0.4s ease, box-shadow 0.4s ease;
            border: 1px solid var(--color-border);
        }

        .house-card:hover {
            transform: translateY(-8px);
            box-shadow: var(--shadow-lg);
        }

        .house-card-img {
            height: 240px;
            overflow: hidden;
        }

        .house-card-img img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.6s ease;
        }

        .house-card:hover .house-card-img img {
            transform: scale(1.08);
        }

        .house-card-text {
            padding: 24px;
        }

        .house-card-text h3 {
            font-size: 22px;
            margin-bottom: 16px;
            color: var(--color-primary);
        }

        .tag-list {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

        .tag-list span {
            padding: 4px 12px;
            background-color: var(--color-bg-section);
            border-radius: 20px;
            font-size: 14px;
            color: var(--color-text-sub);
        }

        /* ===================== 装修模式标签区 ===================== */
        .mode-wrap {
            background-color: var(--color-bg-card);
            padding: 40px;
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-sm);
            border: 1px solid var(--color-border);
        }

        .mode-tags {
            display: flex;
            flex-wrap: wrap;
            gap: 16px;
            justify-content: center;
        }

        .mode-tags span {
            padding: 10px 24px;
            border: 1px solid var(--color-border);
            border-radius: 30px;
            transition: all 0.3s ease;
            cursor: default;
        }

        .mode-tags span:hover {
            background-color: var(--color-primary);
            color: #fff;
            border-color: var(--color-primary);
        }

        /* ===================== 设计风格图集 + 收藏按钮 ===================== */
        .style-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 24px;
        }

        .style-item {
            border-radius: var(--radius-md);
            overflow: hidden;
            position: relative;
            height: 300px;
        }

        .style-item img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: transform 0.5s ease;
        }

        .style-item:hover img {
            transform: scale(1.1);
        }

        .style-name {
            position: absolute;
            left: 0;
            right: 0;
            bottom: 0;
            padding: 16px;
            background: linear-gradient(transparent, rgba(0,0,0,0.7));
            color: #fff;
            font-size: 18px;
        }
        /* 收藏按钮样式 */
        .fav-btn {
            position: absolute;
            top: 12px;
            right: 12px;
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: rgba(255,255,255,0.8);
            border: none;
            font-size: 18px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
        }
        .fav-btn:hover {
            background: #fff;
            transform: scale(1.1);
        }
        .fav-btn.active {
            color: var(--color-fav);
        }

        .design-desc {
            margin-top: 40px;
            padding: 24px;
            background-color: var(--color-bg-card);
            border-radius: var(--radius-md);
            border: 1px solid var(--color-border);
            color: var(--color-text-sub);
        }

        /* ===================== 施工工艺板块 ===================== */
        .process-wrap {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 40px;
            align-items: center;
        }

        .process-img {
            border-radius: var(--radius-lg);
            overflow: hidden;
            box-shadow: var(--shadow-md);
        }

        .process-list {
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .process-item {
            padding: 20px;
            background-color: var(--color-bg-card);
            border-radius: var(--radius-md);
            border: 1px solid var(--color-border);
            box-shadow: var(--shadow-sm);
        }

        .process-item h4 {
            color: var(--color-primary);
            margin-bottom: 8px;
            font-size: 18px;
        }

        .process-item p {
            color: var(--color-text-sub);
            font-size: 15px;
        }

        @media (max-width: 992px) {
            .process-wrap {
                grid-template-columns: 1fr;
            }
        }

        /* ===================== 材料选材板块 ===================== */
        .material-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 32px;
        }

        .material-card {
            background-color: var(--color-bg-card);
            border-radius: var(--radius-lg);
            overflow: hidden;
            border: 1px solid var(--color-border);
            box-shadow: var(--shadow-sm);
            transition: transform 0.3s ease;
        }

        .material-card:hover {
            transform: translateY(-6px);
        }

        .material-card-img {
            height: 200px;
        }

        .material-card-text {
            padding: 24px;
        }

        .material-card-text h4 {
            font-size: 20px;
            margin-bottom: 12px;
            color: var(--color-primary);
        }

        .material-card-text p {
            color: var(--color-text-sub);
            font-size: 15px;
        }

        /* ===================== 全屋定制 & 软装板块 ===================== */
        .custom-soft-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 32px;
        }

        .double-card {
            background-color: var(--color-bg-card);
            border-radius: var(--radius-lg);
            overflow: hidden;
            border: 1px solid var(--color-border);
            box-shadow: var(--shadow-sm);
        }

        .double-card-img {
            height: 260px;
        }

        .double-card-text {
            padding: 24px;
        }

        .double-card-text h3 {
            font-size: 22px;
            margin-bottom: 16px;
            color: var(--color-primary);
        }

        .double-card-text p {
            color: var(--color-text-sub);
        }

        @media (max-width: 768px) {
            .custom-soft-grid {
                grid-template-columns: 1fr;
            }
        }

        /* ===================== 预约表单 ===================== */
        .form-box {
            max-width: 720px;
            margin: 0 auto;
            background-color: var(--color-bg-card);
            padding: 40px;
            border-radius: var(--radius-lg);
            border: 1px solid var(--color-border);
            box-shadow: var(--shadow-md);
        }

        .form-item {
            margin-bottom: 20px;
        }

        .form-item label {
            display: block;
            margin-bottom: 8px;
            font-weight: 500;
        }

        .form-item input,
        .form-item textarea {
            width: 100%;
            padding: 14px;
            border: 1px solid var(--color-border);
            border-radius: var(--radius-sm);
            background-color: var(--color-bg-main);
            color: var(--color-text-main);
            font-size: 16px;
            transition: border-color 0.3s ease;
        }

        .form-item input:focus,
        .form-item textarea:focus {
            outline: none;
            border-color: var(--color-primary);
        }

        /* ===================== 收藏页面样式 ===================== */
        .fav-page {
            display: none;
            min-height: 80vh;
        }
        .fav-page.active {
            display: block;
        }
        .main-page {
            display: block;
        }
        .main-page.hide {
            display: none;
        }
        .fav-empty {
            text-align: center;
            padding: 80px 0;
            font-size: 20px;
            color: var(--color-text-sub);
        }
        .back-btn {
            margin-top: 30px;
        }

        /* ===================== 页脚 ===================== */
        .footer {
            padding: 40px 0;
            background-color: var(--color-bg-card);
            border-top: 1px solid var(--color-border);
            text-align: center;
        }

        .footer p {
            color: var(--color-text-sub);
            margin-bottom: 8px;
        }

        /* 图片懒加载基础样式 */
        img[loading="lazy"] {
            background: #eee;
        }
    </style>
</head>
<body>
    <!-- 顶部导航 -->
    <header class="header">
        <div class="container">
            <nav class="nav">
                <div class="logo">臻品装饰</div>
                <ul class="nav-menu">
                    <li><a href="#house" class="nav-link">房屋类型</a></li>
                    <li><a href="#mode" class="nav-link">装修模式</a></li>
                    <li><a href="#style" class="nav-link">设计风格</a></li>
