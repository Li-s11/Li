                </div>
                <div class="house-grid">
                    <div class="house-card">
                        <div class="house-card-img">
                            <img src="https://picsum.photos/id/164/800/400" alt="家装服务" loading="lazy">
                        </div>
                        <div class="house-card-text">
                            <h3>家装类装修</h3>
                            <div class="tag-list">
                                <span>新房装修</span>
                                <span>毛坯装修</span>
                                <span>老房翻新</span>
                                <span>二手房改造</span>
                                <span>局部翻新</span>
                                <span>精装房改造</span>
                                <span>出租房简装</span>
                            </div>
                        </div>
                    </div>

                    <div class="house-card">
                        <div class="house-card-img">
                            <img src="https://picsum.photos/id/1060/800/400" alt="工装服务" loading="lazy">
