                        <div class="style-name">北欧风</div>
                        <button class="fav-btn"><i class="fa fa-heart-o"></i></button>
                    </div>
                    <div class="style-item" data-id="4" data-name="新中式" data-img="https://picsum.photos/id/1040/600/400">
                        <img src="https://picsum.photos/id/1040/600/400" alt="新中式" loading="lazy">
                        <div class="style-name">新中式</div>
                        <button class="fav-btn"><i class="fa fa-heart-o"></i></button>
                    </div>
                    <div class="style-item" data-id="5" data-name="奶油风" data-img="https://picsum.photos/id/1031/600/400">
                        <img src="https://picsum.photos/id/1031/600/400" alt="奶油风" loading="lazy">
                        <div class="style-name">奶油风</div>
                        <button class="fav-btn"><i class="fa fa-heart-o"></i></button>
                    </div>
                    <div class="style-item" data-id="6" data-name="法式 & 美式" data-img="https://picsum.photos/id/1074/600/400">
