                </div>
            </div>
        </section>

        <!-- 3. 设计风格（带收藏按钮） -->
        <section class="section" id="style">
            <div class="container">
                <div class="section-title">
                    <h2>主流设计风格</h2>
                    <p>点击右上角心形按钮，收藏你喜欢的装修风格</p>
                </div>
                <div class="style-grid" id="styleGrid">
                    <div class="style-item" data-id="1" data-name="现代简约" data-img="https://picsum.photos/id/1057/600/400">
